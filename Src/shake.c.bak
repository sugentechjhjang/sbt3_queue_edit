#include "main.h"

enum shake_state sk_state=stShkrStby;
struct shake_pram shk_pram;
SPI_HandleTypeDef hspi1;



dSPIN_RegsStruct_TypeDef dSPIN_RegsStruct;



/*__packed  struct shake_pram
{
