void edbmt_cmd_send(byte adress, byte inst, byte type ,byte bank, signed long int value)
{
  unsigned char i =0;
  
  static unsigned char edb_data[9] = {0,};  
    if(adress==ADDR_MOTOR_X){
    mt_xstate=busy;  
    err_tmout_set(errXaxi);
  }else if(adress==ADDR_MOTOR_Y){
    mt_ystate=busy;
    err_tmout_set(errYaxi);
  }else{
    mt_zstate=busy;
    err_tmout_set(errZaxi);
  }
  //COM_BACK:   
  edb_data[0] = adress;
  edb_data[1] = inst;
  edb_data[2] = type;
  edb_data[3] = bank;      
  edb_data[4] = value >> 24;
  edb_data[5] = value >> 16;
  edb_data[6] = value >> 8;
  edb_data[7] = value;
  edb_data[8] =0;
  for(i=0;i<8;i++)
  {
    for(i=0;i<8;i++) edb_data[8] += edb_data[i];    
  }        
  
  /*
  if(adress==ADDR_MOTOR_X){
    mt_xstate=busy;  
    err_tmout_set(errXaxi);
  }else if(adress==ADDR_MOTOR_Y){
    mt_ystate=busy;
    err_tmout_set(errYaxi);
  }else{
    mt_zstate=busy;
    err_tmout_set(errZaxi);
  }
    */         
  
  Motor_485_Direction_Set(GPIO_PIN_SET);
  HAL_UART4_Transmit(edb_data);
  Motor_485_Direction_Set(GPIO_PIN_RESET);

  
  com_time_out_set();
  while(mt_xstate==busy)
  {
    if(!call_com_timeout_cnt()){
      com_time_out_set();      
      Motor_485_Direction_Set(GPIO_PIN_SET);
      HAL_UART4_Transmit(edb_data);
      Motor_485_Direction_Set(GPIO_PIN_RESET);
     // goto COM_BACK;
    }
  }
  while(mt_ystate==busy)
  {
    if(!call_com_timeout_cnt()){
      com_time_out_set();      
      Motor_485_Direction_Set(GPIO_PIN_SET);
      HAL_UART4_Transmit(edb_data);
      Motor_485_Direction_Set(GPIO_PIN_RESET);
     // goto COM_BACK;
    }
  }
  while(mt_zstate==busy)
  {
    if(!call_com_timeout_cnt()){
      com_time_out_set();      
      Motor_485_Direction_Set(GPIO_PIN_SET);
      HAL_UART4_Transmit(edb_data);
      Motor_485_Direction_Set(GPIO_PIN_RESET);
      //goto COM_BACK;
    }
  }
   err_tmout_en(FALSE);
   memset(edb_data,0,sizeof(edb_data));
  
}



void edbmt_cmd_send_no_error(byte adress, byte inst, byte type ,byte bank, signed long int value)
{
  unsigned char i =0;
  
  static unsigned char edb_data[9] = {0,};  
 
  edb_data[0] = adress;
  edb_data[1] = inst;
  edb_data[2] = type;
  edb_data[3] = bank;      
  edb_data[4] = value >> 24;
  edb_data[5] = value >> 16;
  edb_data[6] = value >> 8;
  edb_data[7] = value;
  edb_data[8] =0;
  for(i=0;i<8;i++)
  {
    for(i=0;i<8;i++) edb_data[8] += edb_data[i];    
  }        
  
  
  
  Motor_485_Direction_Set(GPIO_PIN_SET);
  HAL_UART4_Transmit(edb_data);
  Motor_485_Direction_Set(GPIO_PIN_RESET);

 
   memset(edb_data,0,sizeof(edb_data));
  
}


//motor_return_data -> 1���� add, 2��° instruction 3���� value
unsigned char EDB2000_Motor_Uart_Data_Get(void)
{    
  unsigned char motor_add_temp =0;
  
 // motor_add_temp = EDB2000_Uart4_Data_Check(motor_uart_data);
  
  if(motor_add_temp)
  {
    if((motor_uart_data[2] == 100) || (motor_uart_data[2] == 5)) //5�� �� �������� Ȯ�� �ʿ�
    {
      motor_rx_comp_flag[motor_add_temp] = 1;
      return 0;
    }
    else if(motor_uart_data[2] == 101) return 2;
    else return 3;    
  }
  return 1;
}


unsigned char EDB2000_Motor_Rx_Check(unsigned char motor_add_temp)
{
  unsigned char edb2000_uart_return_flag=0;
  edb2000_uart_return_flag = EDB2000_Motor_Uart_Data_Get();
  if(!edb2000_uart_return_flag)
  {
    if(motor_rx_comp_flag[motor_add_temp]) return 0;
    else return 2;
  }
  else if(edb2000_uart_return_flag == 1) return 1;
  else return edb2000_uart_return_flag;
}


unsigned char EDB2000_Motor_Position_Reached_Check(unsigned char motor_add_temp)
{
  if(!EDB2000_Command_Send(EDB2000_POSITION_REACHED, motor_add_temp, 0, 0))  
  {
      if(motor_rx_comp_flag[motor_add_temp])
      {
        return motor_uart_data[7];    //1�̸� �Ϸ�
      }    
  }return 0;  
}


unsigned char EDB2000_Motor_Homing_Reached_Check(unsigned char motor_add_temp)
{
  if(!EDB2000_Command_Send(EDB2000_RFS_STATUS, motor_add_temp, 0, 0))
  {    
      if(motor_rx_comp_flag[motor_add_temp])
      {
        return motor_uart_data[7];    //0�̸� �Ϸ�
      }    
  }return 1;  
}


















