void K_Blot_EDB2000_Set_Delay_Milliseconds(unsigned int time_sec)
{
  kblot_edb2000_motor_delay_preview_time= HAL_GetTick();
  kblot_edb2000_motordelay_delay_ms_count = time_sec;
}

unsigned char K_Blot_EDB2000_Run_Delay_Milliseconds(void)
{
    kblot_edb2000_motordelay_current_time = HAL_GetTick();
  
    if (kblot_edb2000_motordelay_current_time >= kblot_edb2000_motor_delay_preview_time)
    {
        if ((kblot_edb2000_motordelay_current_time - kblot_edb2000_motor_delay_preview_time) > kblot_edb2000_motordelay_delay_ms_count) return 1;
    }
    else
    {
        if (((0xFF - kblot_edb2000_motor_delay_preview_time) + kblot_edb2000_motordelay_current_time) > kblot_edb2000_motordelay_delay_ms_count) return 1;
    }
    
    return 0;
}

