void Edb2000_Motor_Init(unsigned char motor_add) 
{
  EDB2000_Parameter_Define();
  EDB2000_Init(motor_add);
  EDB2000_Initalizing(motor_add);
}
//���� ������ ���� �� 
//EDB2000_GAMMA_VMIN, EDB2000_GAMMA_VMAX, EDB2000_CL_CURRENT_MIN
//�� 3���� �Ķ���Ͱ����� �ذ� - ��ü���� �䷸�� ��.
void EDB2000_Initalizing(unsigned char motor_add)
{
  unsigned char i=0;
  unsigned char edb2000_uart_return_flag=0;
  signed long int edb2000_init_data[EDB2000_INIT_END] ={0,};
  
  edb2000_init_data[EDB2000_SET_AUTO_MODE] = 1;
  edb2000_init_data[EDB2000_SET_BUADRATE] = 7;
  edb2000_init_data[EDB2000_SET_SYSTEM_ERROR] = 7;
  
  edb2000_init_data[EDB2000_MAX_SPEED] = 51200;
  edb2000_init_data[EDB2000_ACCELERATOR] = 51200;
  edb2000_init_data[EDB2000_DECELERATE] = 51200;
  
  edb2000_init_data[EDB2000_RFS_MODDE] = 1;
  edb2000_init_data[EDB2000_RFS_SPEED] = 51200;
  edb2000_init_data[EDB2000_RFS_SWITCH_SPEED] = 1280;
  
  edb2000_init_data[EDB2000_SET_CURRENT] = 250; //������
  edb2000_init_data[EDB2000_SET_STANBY_CURRENT] = 50;  
  edb2000_init_data[EDB2000_ENCODER_RESOLUTION] = 10000;
  
  
  edb2000_init_data[EDB2000_GAMMA_VMIN] = 50000;//200000;  //(90000 ~ 200000)��ũ�� ����, ������ ���� �� �Ʒ��� - ���� ���� �߻�
  edb2000_init_data[EDB2000_GAMMA_VMAX] = 1600000; //��ũ ������ �Ʒ��� //51200*5000/60(900000 ~ 1600000)
  edb2000_init_data[EDB2000_CL_MAX_GAMMA] = 255;
  edb2000_init_data[EDB2000_CL_BETA] = 255;     //default 256
  edb2000_init_data[EDB2000_CL_CURRENT_MIN] = 50; //default 50  //������ ������ ���� �ø�. ����.
  edb2000_init_data[EDB2000_CL_CURRENT_MAX] = 255;//step
  edb2000_init_data[EDB2000_CL_START_UP_CURRENT_SCALE] = 100;
  edb2000_init_data[EDB2000_CL_CORRECTION_TOLERANCE] = 255;
  edb2000_init_data[EDB2000_CL_POSITION_WINDOW] = 300;
  edb2000_init_data[EDB2000_CL_UPSCALE_DELAY] = 5000;
  edb2000_init_data[EDB2000_CL_DOWNSCALE_DELAY] = 10000;
  edb2000_init_data[EDB2000_CL_CORRECTION_VELOCITY_P] = 3000;
  edb2000_init_data[EDB2000_CL_CORRECTION_VELOCITY_I] = 20;
  edb2000_init_data[EDB2000_CL_CORRECTION_VELOCITY_I_CLIPPING] = 2000;
  edb2000_init_data[EDB2000_CL_CORRECTION_VELOCITY_DV_CLOCK] = 0;
  edb2000_init_data[EDB2000_CL_CORRECTION_VELOCITY_DV_CLIPPING] = 100000;
  edb2000_init_data[EDB2000_CL_CORRECTION_POSITION_P] = 65536;  //default 65536
  edb2000_init_data[EDB2000_CL_CHOPPER_BLANK_TIME] = 1; //Enable 1:set 0:reset
  edb2000_init_data[EDB2000_CL_CORRECTION_RELATIVE_POSITION_OPTION] = 1;
  edb2000_init_data[EDB2000_CL_TURN_ON_CLOSED_LOOP] = 1;  
  edb2000_init_data[EDB2000_CL_GET_CLLOOP_CHECK] = 0; //0�̸� retry, 1�̸� complete
  
  
  if(motor_add == ADDR_MOTOR_Z)
  {
    edb2000_init_data[EDB2000_RFS_SPEED] = -51200;
    edb2000_init_data[EDB2000_RFS_SWITCH_SPEED] = -5120;
  }
  
  for(i= EDB2000_INIT_START+1;i< EDB2000_INIT_END;i++)
  {
      do
      {
        edb2000_uart_return_flag= EDB2000_Command_Send(i, motor_add, 0, edb2000_init_data[i]);
      }while(edb2000_uart_return_flag == 1);    
  }
}


