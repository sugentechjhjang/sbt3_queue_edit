void Motor_485_Direction_Set(GPIO_PinState pin_state)
{
  HAL_GPIO_WritePin(UART4_DIR_GPIO_Port, UART4_DIR_Pin, pin_state);  // DIR RS-485
}


#if 1
unsigned char EDB2000_Command_Send(unsigned char commnad_list, unsigned char address, unsigned char bank, signed long int value)
{
  unsigned char i =0;
  
  static unsigned char edb2000_data_temp[9] = {0,};  
  static unsigned char motor_retry_count =0;  
  static unsigned char edb2000_command_send_process =0;
  static unsigned char preview_motor_add =0;
  static unsigned char emergency_commnad_flag =0;
   
  if(commnad_list)
  {
      if((commnad_list == EDB2000_STOP) && !emergency_commnad_flag)
      {
        edb2000_command_send_process =0;
        emergency_commnad_flag =1;
      }
      
      if((!preview_motor_add) || (preview_motor_add == address))
      {
        switch(edb2000_command_send_process)
        {
        case 0:    
          
              preview_motor_add = address;
              edb2000_data_temp[0] = address;
              edb2000_data_temp[1] = edb2000_inst_type_value[commnad_list][EDB2000_INST];
              edb2000_data_temp[2] = edb2000_inst_type_value[commnad_list][EDB2000_TYPE];
              edb2000_data_temp[3] = bank;      
              edb2000_data_temp[4] = value >> 24;
              edb2000_data_temp[5] = value >> 16;
              edb2000_data_temp[6] = value >> 8;
              edb2000_data_temp[7] = value;
              edb2000_command_send_process++;
              break;
          case 1:
              edb2000_data_temp[8] =0;
              for(i=0;i<8;i++)
              {
                for(i=0;i<8;i++) edb2000_data_temp[8] += edb2000_data_temp[i];    
              }        
              motor_rx_comp_flag[address] = 0;
              edb2000_command_send_process++;
              break;
          case 2:
              Motor_485_Direction_Set(GPIO_PIN_SET);
              HAL_UART4_Transmit(edb2000_data_temp);
              Motor_485_Direction_Set(GPIO_PIN_RESET);
              K_Blot_EDB2000_Set_Delay_Milliseconds(MOTOR_485_DIRECTION_DELAY);
              edb2000_command_send_process++;
              motor_retry_count++;
              break;
          case 3:
              if(K_Blot_EDB2000_Run_Delay_Milliseconds())
              {
                edb2000_command_send_process++;
              }
            break;
          case 4:
              if(!EDB2000_Motor_Rx_Check(address))
              {
                edb2000_command_send_process++;        
              }
              else 
              {
                if(motor_retry_count >= MOTOR_SEND_MAX_RETRY) edb2000_command_send_process = 6;
                else edb2000_command_send_process = 2;    
              }//error ó�� �ʿ�
              break;
          case 5:   //complete
              edb2000_command_send_process =0;
              emergency_commnad_flag =0;
              preview_motor_add = 0;
              motor_retry_count =0;
              commnad_list =0;
              return  0;
          case 6:   //error
              edb2000_command_send_process =0;
              emergency_commnad_flag =0;  
              motor_retry_count =0;
              preview_motor_add =0;
              return 2;
            }
      }
  }return 1;
}
