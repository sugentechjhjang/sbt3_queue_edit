   Motor_Uart4_Data_Send(motor_add, INST_SAP, 127, 0, 1);       //Relative Position Option
   Motor_Uart4_Data_Send(motor_add, INST_SAP, 129, 0, 1);       //Turn on closed loop
   
   Motor_Uart4_Data_Send(motor_add, INST_SAP, 133, 0, 0);       // Get closed loop check //0 �̸� retry 1�̸� complete ----------Ȯ�� �� ��  
   Motor_Uart4_Data_Send(motor_add, INST_SAP, 4, 0, 1500*51200/60);       //velocity: 1280000
   
   Motor_Uart4_Data_Send(motor_add, INST_SAP, 5, 0, 10*1500*51200/60);    //Acc: 12800000
   Motor_Uart4_Data_Send(motor_add, INST_SAP, 17, 0, 10*1500*51200/60);   //Dec: 12800000
   Motor_Uart4_Data_Send(motor_add, INST_SAP, 6, 0, 200);       //������
   Motor_Uart4_Data_Send(motor_add, INST_SAP, 193, 0, 1);       // RFS ��� ����
}
