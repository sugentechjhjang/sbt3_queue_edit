void send_test(uint8_t *data, unsigned char length)
{
  HAL_UART_Transmit(&huart1, data,length, 1000);
}


#define TRANSMIT_BUF_LENGTH 50
byte usb_transmit_bufs[TRANSMIT_BUF_LENGTH];
void usb_send_pack(enum cntrl_event cmd, uint8_t *data)
{
  uint8_t chksum=0;
  uint16_t ev_cmd=cmd;
  int i;
  // if(state==stErr)
     //ev_cmd|=0x8000;
   
//   if(cmd==eventEquiType)
//     ev_cmd=0;
//   
   usb_transmit_bufs[0]=PC_STX;
   sprintf((char*)&usb_transmit_bufs[1], "%X", (ev_cmd>>12)&0x0f);
   sprintf((char*)&usb_transmit_bufs[2], "%X", (ev_cmd>>8)&0x0f);
   sprintf((char*)&usb_transmit_bufs[3], "%X", (ev_cmd>>4)&0x0f);
   sprintf((char*)&usb_transmit_bufs[4], "%X", ev_cmd&0x0f); 
   usb_transmit_bufs[5]|=0x30;
   usb_transmit_bufs[6]|=0x38;
   for(i = 0; i < 4 + 1; i++)
    sprintf((char*)&usb_transmit_bufs[(i*2)+7], "%02X", *(data+i));
    for(i = 0; i < 14; i++) chksum += usb_transmit_bufs[i + 1];
    sprintf((char*)&usb_transmit_bufs[15], "%02X]", chksum);
   usb_transmit_bufs[17]|=PC_ETX;
  // BSP_UART_PutIT_Byte(0, usb_transmit_bufs,18);
   HAL_UART_Transmit(&huart1, usb_transmit_bufs,18, 1000);
   memset(usb_transmit_bufs,0,TRANSMIT_BUF_LENGTH);
}

void pc_send_pack(uint16_t cmd, uint8_t *data)
{
  uint8_t chksum=0;
  uint16_t ev_cmd=cmd;
  int i;
  // if(state==stErr)
     //ev_cmd|=0x8000;
   
//   if(cmd==eventEquiType)
//     ev_cmd=0;
//   
   usb_transmit_bufs[0]=PC_STX;
   sprintf((char*)&usb_transmit_bufs[1], "%X", (ev_cmd>>12)&0x0f);
   sprintf((char*)&usb_transmit_bufs[2], "%X", (ev_cmd>>8)&0x0f);
   sprintf((char*)&usb_transmit_bufs[3], "%X", (ev_cmd>>4)&0x0f);
   sprintf((char*)&usb_transmit_bufs[4], "%X", ev_cmd&0x0f); 
   usb_transmit_bufs[5]|=0x30;
   usb_transmit_bufs[6]|=0x38;
   for(i = 0; i < 4 + 1; i++)
    sprintf((char*)&usb_transmit_bufs[(i*2)+7], "%02X", *(data+i));
    for(i = 0; i < 14; i++) chksum += usb_transmit_bufs[i + 1];
    sprintf((char*)&usb_transmit_bufs[15], "%02X]", chksum);
   usb_transmit_bufs[17]|=PC_ETX;
  // BSP_UART_PutIT_Byte(0, usb_transmit_bufs,18);
   HAL_UART_Transmit(&huart1, usb_transmit_bufs,18, 1000);
   memset(usb_transmit_bufs,0,TRANSMIT_BUF_LENGTH);
}



char *pnt;

event dev_cfg_ctrl(event event)
{
byte dev_send_buf[4]={0,};  
  switch(event)
  {
  case eventEquiSN:
    pnt=FW_VER;
    dev_send_buf[0]=*pnt;
    dev_send_buf[1]=*(pnt+2);
    dev_send_buf[2]=*(pnt+4);
    dev_send_buf[3]=*(pnt+5);
    usb_send_pack(eventEquiSN,dev_send_buf);
    break;
 /* case eventPause:
    if(!usb_data_buf[3]){
     ave_pause(pau_queue,&pau_head,&pau_tail);
    }else if(usb_data_buf[3]==1){
      get_pause(pau_queue,pau_head,pau_tail);
    }
    break;*/
    
    
 // case eventFwVer:
  //  dev_send_buf[3]=DEV_SN;
  //  usb_send_pack(eventFwVer,dev_send_buf);
//    break;
  case eventReserve0:
    usb_send_pack(eventReserve0,dev_send_buf);
    break;
  
  default: 
    if((event_cmd&0xf000)==0xc000){
      app_data_write(event_cmd&0x0fff,usb_data_buf);
      pc_send_pack(event_cmd,usb_data_buf);
      event_cmd=0;
    }else if((event_cmd&0xf000)==0xd000){
      app_data_read(event_cmd&0x0fff,dev_send_buf);
      pc_send_pack(event_cmd,dev_send_buf);
      event_cmd=0;
    }
  break;
  }
  return event;
}


int32_t merge_32bit(int32_t out_data, byte* in_data )
{
  out_data=*in_data<<24;
  out_data|=*(in_data+1)<<16;
  out_data|=*(in_data+2)<<8;
  out_data|=*(in_data+3);
  
  return out_data;
}

void sort_8bit(int32_t in_data, byte* out_data )
{
  *out_data=in_data>>24;
  *(out_data+1)=in_data>>16;
  *(out_data+2)=in_data>>8;
  *(out_data+3)=in_data;
}
                                         
                                         
                                         
                                         
                                         
                                         
                                         

