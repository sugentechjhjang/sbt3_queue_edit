#include "main.h"



UART_HandleTypeDef huart1;



#define PCBUF_QUEUE_LENGTH 100

struct
  {
    byte pc_head;
    byte pc_tail;
    byte pc_queue[PCBUF_QUEUE_LENGTH];
  }pc_buf_data={0,0};

void give_pc_buf_data(byte buf, byte nomore)
  {
    if(pc_buf_data.pc_tail==255){  // if it's end 
       pc_buf_data.pc_tail=pc_buf_data.pc_head;
       return;
    }
    if(nomore)  // no more needed
      {
        for(byte ev=pc_buf_data.pc_head; ev!=pc_buf_data.pc_tail; )
          {
            if(pc_buf_data.pc_queue[ev]==buf)  // return;
              return;
            if(++ev==PCBUF_QUEUE_LENGTH)  // end of Queue
              ev=0;
          }
      }
    pc_buf_data.pc_queue[pc_buf_data.pc_tail++]=buf;  // input the event
    if(pc_buf_data.pc_tail==PCBUF_QUEUE_LENGTH) // event tail 
      pc_buf_data.pc_tail=0;
    if(pc_buf_data.pc_tail==pc_buf_data.pc_head) 
      {
        pc_buf_data.pc_head=pc_buf_data.pc_tail;
        pc_buf_data.pc_tail=255;
      }  
  }

byte pc_get_buf()
{
  byte tmp;
  if(pc_buf_data.pc_tail==255)
  {
    pc_buf_data.pc_tail=pc_buf_data.pc_head;
    // limo_ctrl.error_handling(ERR_QUEUEFULL);	XYZ	
    return 0;
  }  
  if(pc_buf_data.pc_head==pc_buf_data.pc_tail) 
    return 0;
  tmp=pc_buf_data.pc_queue[pc_buf_data.pc_head++];
  if(pc_buf_data.pc_head==PCBUF_QUEUE_LENGTH)
    pc_buf_data.pc_head=0;
  return tmp;
}

