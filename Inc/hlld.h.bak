 {
  uint ra;
  uint rb;
  uint sws;
  uint off_set;
  int16_t min_std;
  int16_t max_std;
  int16_t slop_min_std;
  int16_t slop_max_std;
 };
#pragma pack(pop)
 
extern struct smple_pram smp_pram;

