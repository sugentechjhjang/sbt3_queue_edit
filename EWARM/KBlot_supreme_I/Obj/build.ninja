build KBlot_supreme_I.pbd : link KBlot_supreme_I_part0.pbi KBlot_supreme_I_part1.pbi KBlot_supreme_I_part2.pbi KBlot_supreme_I_part3.pbi KBlot_supreme_I_part4.pbi KBlot_supreme_I_part5.pbi KBlot_supreme_I_part6.pbi
build KBlot_supreme_I.pbw : browsedata KBlot_supreme_I.pbd


