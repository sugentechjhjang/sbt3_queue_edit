build KBlot_supreme_I_part0.pbi : link 17HS3410_Dspin.pbi adc.pbi C3000_SYRINGE.pbi cam_led.pbi cntrl.pbi eeprom_ctrl.pbi error.pbi
build KBlot_supreme_I_part1.pbi : link event.pbi hlld.pbi hs_Common_Utill.pbi hsAT24_EEPROM.pbi key_polling.pbi main.pbi Max5500.pbi
build KBlot_supreme_I_part2.pbi : link MG90_SERVOMOTOR.pbi pump.pbi SE655_Barcode.pbi shake.pbi sq.pbi stepping.pbi stepping_edb_ctrl.pbi
build KBlot_supreme_I_part3.pbi : link stepping_leadshine_ctrl.pbi stm32f1xx_hal_msp.pbi stm32f1xx_it.pbi sys_func.pbi timer.pbi uart_pc.pbi system_stm32f1xx.pbi
build KBlot_supreme_I_part4.pbi : link stm32f1xx_hal.pbi stm32f1xx_hal_adc.pbi stm32f1xx_hal_adc_ex.pbi stm32f1xx_hal_cortex.pbi stm32f1xx_hal_dma.pbi stm32f1xx_hal_flash.pbi stm32f1xx_hal_flash_ex.pbi
